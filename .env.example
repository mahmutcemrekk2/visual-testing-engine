# AI Visual Testing Engine Configuration
# Bu dosyayı projeyi ilk kurduğunuzda ".env" adıyla kopyalayın
# ve ilgili API anahtarlarınızı oraya yapıştırın.

# ─── AI Provider Seçimi ───────────────────────────────
# "gemini" → Google Gemini Vision (varsayılan)
# "openai" → OpenAI GPT-4o Vision
AI_PROVIDER=gemini

# ─── Google Gemini API Key (AI_PROVIDER=gemini ise gerekli) ───
GEMINI_API_KEY=your_gemini_api_key_here

# ─── OpenAI API Key (AI_PROVIDER=openai ise gerekli) ──────────
# OPENAI_API_KEY=sk_your_openai_api_key_here

PORT=3000
